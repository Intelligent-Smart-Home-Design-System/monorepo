{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SmartLamp",
  "description": "A smart home light bulb or lamp",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name as it appears in the listing, e.g. 'Yeelight Smart Bulb W3'"
    },
    "brand": {
      "type": "string",
      "description": "Normalized lowercase brand name, e.g. 'yeelight', 'philips', 'ikea'"
    },
    "model": {
      "type": "string",
      "description": "Model identifier as stated by the manufacturer, e.g. 'YLDP010'."
    },
    "ecosystem": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "yandex",
          "apple",
          "google",
          "aqara",
          "tuya",
          "xiaomi",
          "digma",
          "sber",
          "vk",
          "ekf"
        ]
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Smart home ecosystems this bulb works with, through any connection path."
    },
    "protocol": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "zigbee",
          "z-wave",
          "wifi",
          "bluetooth",
          "ble",
          "matter-over-wifi",
          "matter-over-thread"
        ]
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Wireless protocols supported by this device."
    },
    "wattage_w": {
      "type": "number",
      "minimum": 0.5,
      "maximum": 100,
      "description": "How much power the bulb consumes in watts, e.g. 8.5."
    },
    "brightness_lm": {
      "type": "number",
      "minimum": 1,
      "maximum": 5000,
      "description": "Maximum brightness in lumens, e.g. 800. Higher is brighter."
    },
    "color_temp_min_k": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 6500,
      "description": "Warmest color temperature in Kelvin, e.g. 2700. Lower values are more yellow/warm."
    },
    "color_temp_max_k": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 10000,
      "description": "Coolest color temperature in Kelvin, e.g. 6500. Higher values are more white/cool."
    },
    "rgb_support": {
      "type": "boolean",
      "description": "Whether the bulb can display colors, not just white light."
    },
    "cri": {
      "type": "integer",
      "minimum": 60,
      "maximum": 100,
      "description": "Color Rendering Index - how accurately the bulb reproduces colors compared to natural light. 80+ is good, 90+ is excellent."
    },
    "dimmable": {
      "type": "boolean",
      "description": "Whether the bulb supports dimming via the app or ecosystem."
    },
    "voltage_min_v": {
      "type": "integer",
      "minimum": 12,
      "maximum": 240,
      "description": "Minimum operating voltage in volts, e.g. 220."
    },
    "voltage_max_v": {
      "type": "integer",
      "minimum": 12,
      "maximum": 240,
      "description": "Maximum operating voltage in volts, e.g. 240."
    },
    "lifespan_hours": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 100000,
      "description": "Rated lifespan in hours as stated by the manufacturer, e.g. 15000."
    },
    "type": {
      "const": "smart_lamp"
    },
    "socket_type": {
      "type": "string",
      "enum": [
        "E27",
        "E14",
        "GU10",
        "GU5.3",
        "E40",
        "integrated"
      ],
      "description": "The socket or base type this bulb fits into. 'integrated' for fixtures where the bulb is not replaceable, e.g. a smart light strip or panel."
    }
  },
  "required": [
    "name",
    "brand",
    "model",
    "ecosystem",
    "protocol",
    "type",
    "socket_type"
  ],
  "additionalProperties": false
