{
  "name": "@smart-home/frontend-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:sim-ui": "npm run dev --workspace @smart-home/sim-ui",
    "preview:sim-ui": "npm run preview --workspace @smart-home/sim-ui",
    "build": "npm run build --workspaces --if-present",
    "build:sim-ui": "npm run build --workspace @smart-home/sim-ui",
    "test:e2e:simulation": "playwright test --config playwright.simulation.config.ts",
    "lint": "npm run lint --workspaces --if-present"
  },
  "packageManager": "npm@10",
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
