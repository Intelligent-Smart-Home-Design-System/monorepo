{
  "traits": {
    "base": {
      "properties": {
        "name": { "type": "string", "description": "Product name as displayed in the store" },
        "brand": { "type": "string", "description": "Normalized lower‑case brand name, e.g. 'aqara', 'xiaomi'" },
        "model": { "type": "string", "description": "Manufacturer model or SKU" },
        "price": { "type": "number", "description": "Price in local currency", "minimum": 0 },
        "articul_YANDEX": { "type": "string", "description": "Yandex Market article ID" }
      },
      "required": ["name", "brand", "model"]
    },
    "connectivity": {
      "properties": {
        "ecosystem": {
          "type": "array",
          "items": { "type": "string", "enum": ["yandex", "apple", "google", "aqara", "tuya", "xiaomi", "smartthings", "homekit"] },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Smart home ecosystems the device works with"
        },
        "protocol": {
          "type": "array",
          "items": { "type": "string", "enum": ["zigbee", "z-wave", "wifi", "bluetooth", "matter", "thread"] },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Communication protocols supported by the device"
        }
      },
      "required": ["ecosystem", "protocol"]
    },
    "battery_operated": {
      "properties": {
        "battery_type": { "type": "string", "enum": ["CR2032", "CR2450", "CR123A", "AA", "AAA", "18650", "built-in"] },
        "battery_life_months": { "type": "number", "minimum": 1, "description": "Estimated battery life" },
        "rechargeable": { "type": "boolean" }
      },
      "required": []
    },
    "eval_lighting": {
      "properties": {
        "luminous_flux": { "type": "number", "description": "Световой поток в люменах. Основа для оценки яркости.", "min": 400, "max": 1500, "weight": 0.6 },
        "cri": { "type": "number", "description": "Индекс цветопередачи (CRI). Влияет на естественность освещения.", "min": 70, "max": 100, "weight": 0.4 }
      },
      "required": ["luminous_flux"]
    },
    "eval_switch": {
      "properties": {
        "max_load_watt": { "type": "number", "description": "Максимальная мощность нагрузки. Чем выше, тем универсальнее реле/розетка.", "min": 1000, "max": 3680, "weight": 0.7 },
        "has_energy_monitoring": { "type": "boolean", "description": "Наличие мониторинга электроэнергии (дает фиксированный бонус).", "bonus": 0.3 }
      },
      "required": ["max_load_watt"]
    },
    "eval_sensor": {
      "properties": {
        "battery_life_months": { "type": "number", "description": "Заявленный срок службы от одной батареи в месяцах.", "min": 6, "max": 36, "weight": 0.6 },
        "measurement_error_margin": { "type": "number", "description": "Погрешность измерений. Требует обратной нормализации.", "min": 0.1, "max": 2.0, "weight": 0.4, "inverse": true }
      },
      "required": ["battery_life_months"]
    },
    "eval_security": {
      "properties": {
        "resolution_mp": { "type": "number", "description": "Разрешение камеры в мегапикселях.", "min": 1.0, "max": 8.0, "weight": 0.6 },
        "fov_degrees": { "type": "number", "description": "Угол обзора объектива в градусах.", "min": 90, "max": 180, "weight": 0.4 }
      },
      "required": ["resolution_mp"]
    },
    "eval_climate": {
      "properties": {
        "noise_level_db": { "type": "number", "description": "Уровень шума в децибелах (обратная нормализация).", "min": 20, "max": 65, "weight": 0.5, "inverse": true },
        "coverage_area_sqm": { "type": "number", "description": "Эффективная площадь обслуживания (м2).", "min": 10, "max": 50, "weight": 0.5 }
      },
      "required": ["noise_level_db"]
    },
    "eval_infra": {
      "properties": {
        "max_child_devices": { "type": "number", "description": "Максимальное количество подключаемых sub-устройств.", "min": 32, "max": 256, "weight": 0.6 },
        "has_local_control": { "type": "boolean", "description": "Поддержка локального выполнения сценариев без интернета.", "bonus": 0.4 }
      },
      "required": ["max_child_devices"]
    }
  },
  "types": {
    "water_leak_sensor": {
      "description": "Detects water leaks. Typically placed under sinks.",
      "traits": ["base", "connectivity", "battery_operated", "eval_sensor"],
      "extra_schema": {
        "properties": { "type": { "const": "water_leak_sensor" } },
        "required": ["type"]
      }
    },
    "temperature_sensor": {
      "description": "Measures ambient temperature and humidity.",
      "traits": ["base", "connectivity", "battery_operated", "eval_sensor"],
      "extra_schema": {
        "properties": { "type": { "const": "temperature_sensor" } },
        "required": ["type"]
      }
    },
    "smart_lamp": {
      "description": "Smart light bulb or luminaire.",
      "traits": ["base", "connectivity", "eval_lighting"],
      "extra_schema": {
        "properties": {
          "type": { "const": "smart_lamp" },
          "mount_type": { "type": "string", "enum": ["ceiling", "wall", "table", "floor"] }
        },
        "required": ["type"]
      }
    },
    "smart_plug": {
      "description": "Smart plug that controls connected appliances",
      "traits": ["base", "connectivity", "eval_switch"],
      "extra_schema": {
        "properties": { "type": { "const": "smart_plug" } },
        "required": ["type"]
      }
    }
  }
}