{
  "title": "Типы устройств и их общие части (трейты)",
  "description": "Объединённые описания типов умных устройств и их переиспользуемых характеристик",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "description": "Наборы характеристик, общих для разных типов устройств",
      "properties": {
        "base": {
          "type": "object",
          "description": "Основная информация, которая есть у любого устройства",
          "properties": {
            "name": { "type": "string", "description": "Название товара, как в магазине" },
            "brand": { "type": "string", "description": "Название бренда маленькими буквами, например 'aqara', 'xiaomi'" },
            "model": { "type": "string", "description": "Модель или артикул производителя" },
            "price": { "type": "number", "description": "Цена в рублях или другой местной валюте", "minimum": 0 },
            "articul_YANDEX": { "type": "string", "description": "Артикул Яндекса, если есть" }
          },
          "required": ["name", "brand", "model"]
        },
        "connectivity": {
          "type": "object",
          "description": "Как устройство подключается к умному дому",
          "properties": {
            "ecosystem": {
              "type": "array",
              "description": "С какими экосистемами работает",
              "items": {
                "type": "string",
                "enum": ["yandex", "apple", "google", "aqara", "tuya", "xiaomi", "smartthings", "homekit"]
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "protocol": {
              "type": "array",
              "description": "Какие протоколы связи использует",
              "items": {
                "type": "string",
                "enum": ["zigbee", "z-wave", "wifi", "bluetooth", "matter", "thread"]
              },
              "minItems": 1,
              "uniqueItems": true
            }
          },
          "required": ["ecosystem", "protocol"]
        },
        "battery_operated": {
          "type": "object",
          "description": "Характеристики питания от батареек",
          "properties": {
            "battery_type": {
              "type": "string",
              "enum": ["CR2032", "CR2450", "CR123A", "AA", "AAA", "18650", "built-in"],
              "description": "Тип батарейки или аккумулятора"
            },
            "battery_life_months": {
              "type": "number",
              "minimum": 1,
              "maximum": 300,
              "description": "Сколько месяцев примерно хватает батарейки"
            },
            "rechargeable": {
              "type": "boolean",
              "description": "Есть ли встроенный аккумулятор (можно заряжать)"
            }
          },
          "required": []
        },
        "ip_rated": {
          "type": "object",
          "description": "Защита от воды и пыли (класс IP)",
          "properties": {
            "ip_rating": {
              "type": "string",
              "pattern": "^IP([0-6]|X)([0-9]|X)([A-D])?([HMSW])?$",
              "description": "Код защиты, например IP67, IP44"
            }
          },
          "required": []
        },
        "lighting": {
          "type": "object",
          "description": "Характеристики света (для лампочек и светильников)",
          "properties": {
            "power": { "type": "number", "description": "Мощность в ваттах", "minimum": 0 },
            "voltage": {
              "type": "object",
              "description": "Рабочее напряжение (от и до)",
              "properties": {
                "min": { "type": "number", "minimum": 0 },
                "max": { "type": "number", "minimum": 0 }
              },
              "required": ["min", "max"]
            },
            "lifetime": { "type": "number", "description": "Срок службы в часах", "minimum": 0 },
            "color_temperature": {
              "type": "number",
              "description": "Цветовая температура в кельвинах",
              "minimum": 1000,
              "maximum": 10000
            },
            "color_rendering_index": {
              "type": "number",
              "description": "Индекс цветопередачи (CRI)",
              "minimum": 0,
              "maximum": 100
            },
            "color_mode": {
              "type": "string",
              "enum": ["RGB", "RGBW", "CCT", "Dimmable", "On/Off"],
              "description": "Режимы цвета"
            }
          },
          "required": ["power", "voltage"]
        },
        "sensor": {
          "type": "object",
          "description": "Общие свойства датчиков (точность)",
          "properties": {
            "accuracy": {
              "type": "number",
              "description": "Точность измерений (в процентах или абсолютная)",
              "minimum": 0
            }
          },
          "required": []
        },
        "motion_detection": {
          "type": "object",
          "description": "Свойства датчика движения",
          "properties": {
            "detection_range": {
              "type": "number",
              "description": "Максимальная дальность обнаружения в метрах",
              "minimum": 0
            },
            "detection_angle": {
              "type": "number",
              "description": "Угол обзора в градусах",
              "minimum": 0,
              "maximum": 360
            }
          },
          "required": []
        }
      },
      "additionalProperties": false
    },
    "types": {
      "type": "object",
      "description": "Описания конкретных типов устройств",
      "properties": {
        "water_leak_sensor": {
          "type": "object",
          "description": "Датчик протечки воды. Устанавливается под раковиной, возле труб и т.п.",
          "properties": {
            "traits": {
              "type": "array",
              "description": "Список трейтов, применимых к этому типу",
              "items": {
                "type": "string",
                "enum": ["base", "connectivity", "battery_operated", "ip_rated"]
              },
              "uniqueItems": true,
              "minItems": 1
            },
            "extra_schema": {
              "type": "object",
              "description": "Дополнительные поля, специфичные для датчика протечки",
              "properties": {
                "type": { "const": "water_leak_sensor" },
                "has_audio_alert": {
                  "type": "boolean",
                  "description": "Пищит ли, когда обнаруживает протечку"
                },
                "audio_alert_volume_db": {
                  "type": "number",
                  "minimum": 60,
                  "maximum": 120,
                  "description": "Громкость звукового сигнала в децибелах"
                },
                "detects_leaks_above": {
                  "type": "boolean",
                  "description": "Видит ли воду, капающую сверху (например, на контакты)"
                },
                "detects_leaks_below": {
                  "type": "boolean",
                  "description": "Видит ли воду снизу (на полу)"
                },
                "min_detected_water_level_mm": {
                  "type": "number",
                  "minimum": 0.1,
                  "maximum": 10,
                  "description": "Минимальная толщина слоя воды, которую может заметить (в миллиметрах)"
                }
              },
              "required": ["type"],
              "additionalProperties": false
            }
          },
          "required": ["traits", "extra_schema"],
          "additionalProperties": false
        },
        "temperature_sensor": {
          "type": "object",
          "description": "Датчик температуры (и, опционально, влажности)",
          "properties": {
            "traits": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["base", "connectivity", "battery_operated", "ip_rated", "sensor"]
              },
              "uniqueItems": true,
              "minItems": 1
            },
            "extra_schema": {
              "type": "object",
              "properties": {
                "type": { "const": "temperature_sensor" },
                "temperature_range": {
                  "type": "object",
                  "description": "Диапазон измеряемых температур",
                  "properties": {
                    "min": { "type": "number" },
                    "max": { "type": "number" }
                  },
                  "required": ["min", "max"],
                  "additionalProperties": false
                },
                "humidity_sensor": {
                  "type": "boolean",
                  "description": "Есть ли датчик влажности"
                },
                "accuracy_temperature": {
                  "type": "number",
                  "description": "Точность измерения температуры (± сколько)"
                },
                "accuracy_humidity": {
                  "type": "number",
                  "description": "Точность измерения влажности (± %)"
                }
              },
              "required": ["type", "temperature_range"],
              "additionalProperties": false
            }
          },
          "required": ["traits", "extra_schema"],
          "additionalProperties": false
        },
        "motion_sensor": {
          "type": "object",
          "description": "Датчик движения",
          "properties": {
            "traits": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["base", "connectivity", "battery_operated", "ip_rated", "motion_detection"]
              },
              "uniqueItems": true,
              "minItems": 1
            },
            "extra_schema": {
              "type": "object",
              "properties": {
                "type": { "const": "motion_sensor" }
              },
              "required": ["type"],
              "additionalProperties": false
            }
          },
          "required": ["traits", "extra_schema"],
          "additionalProperties": false
        },
        "smart_lamp": {
          "type": "object",
          "description": "Умная лампа или светильник",
          "properties": {
            "traits": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["base", "connectivity", "lighting"]
              },
              "uniqueItems": true,
              "minItems": 1
            },
            "extra_schema": {
              "type": "object",
              "properties": {
                "type": { "const": "smart_lamp" },
                "mount_type": {
                  "type": "string",
                  "enum": ["ceiling", "wall", "table", "floor"],
                  "description": "Как обычно крепится: на потолок, на стену, настольная, напольная"
                }
              },
              "required": ["type"],
              "additionalProperties": false
            }
          },
          "required": ["traits", "extra_schema"],
          "additionalProperties": false
        },
        "smart_plug": {
          "type": "object",
          "description": "Умная розетка",
          "properties": {
            "traits": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["base", "connectivity"]
              },
              "uniqueItems": true,
              "minItems": 1
            },
            "extra_schema": {
              "type": "object",
              "properties": {
                "type": { "const": "smart_plug" },
                "max_power": {
                  "type": "number",
                  "description": "Максимальная мощность нагрузки в ваттах",
                  "minimum": 0
                },
                "voltage": {
                  "type": "object",
                  "description": "Диапазон рабочего напряжения",
                  "properties": {
                    "min": { "type": "number", "minimum": 0 },
                    "max": { "type": "number", "minimum": 0 }
                  },
                  "required": ["min", "max"],
                  "additionalProperties": false
                },
                "usb_ports": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Сколько USB-портов есть на розетке"
                },
                "child_lock": {
                  "type": "boolean",
                  "description": "Есть ли защита от детей"
                },
                "power_consumption": {
                  "type": "number",
                  "description": "Сколько ватт потребляет сама розетка в режиме ожидания"
                }
              },
              "required": ["type", "max_power", "voltage"],
              "additionalProperties": false
            }
          },
          "required": ["traits", "extra_schema"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false,
      "required": ["water_leak_sensor", "temperature_sensor", "motion_sensor", "smart_lamp", "smart_plug"]
    }
  },
  "required": ["traits", "types"],
  "additionalProperties": false
}