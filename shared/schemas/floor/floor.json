{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shared/schemas/floor/floor.json",
  "title": "Floor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meta",
    "walls",
    "doors",
    "windows",
    "rooms",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "source_ref",
        "units"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "source_ref": {
          "type": "string"
        },
        "units": {
          "type": "string"
        }
      }
    },
    "walls": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/wall"
      }
    },
    "doors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/door"
      }
    },
    "windows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/window"
      }
    },
    "rooms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/room"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  },
  "$defs": {
    "point": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "number"
        },
        {
          "type": "number"
        }
      ]
    },
    "point_list": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/point"
      }
    },
    "wall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "points",
        "width"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "points": {
          "$ref": "#/$defs/point_list"
        },
        "width": {
          "type": "number"
        }
      }
    },
    "door": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "points",
        "width",
        "rooms"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "points": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/point"
          }
        },
        "width": {
          "type": "number"
        },
        "rooms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "opens_towards_room": {
          "type": "string"
        },
        "swing": {
          "type": "string"
        }
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "points",
        "width",
        "rooms"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "points": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/point"
          }
        },
        "width": {
          "type": "number"
        },
        "rooms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "room": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "area",
        "area_m2",
        "windows",
        "doors",
        "walls"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "area": {
          "$ref": "#/$defs/point_list"
        },
        "area_m2": {
          "type": "number"
        },
        "windows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "doors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "walls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
